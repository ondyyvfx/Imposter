# ─────────────────────────────────────────────────────────────
# Скопируй этот файл в .env.local и подставь значения из Supabase
# (Supabase Dashboard → Project Settings → API)
# ─────────────────────────────────────────────────────────────

# URL проекта (выглядит как https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Публичный anon-ключ (нужен браузеру для realtime-обновлений лобби)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Секретный service_role ключ (используется ТОЛЬКО на сервере — никогда не попадает в браузер!)
SUPABASE_SERVICE_ROLE_KEY=
